<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    Root is now a vertical LinearLayout so the MaterialToolbar sits above
    the ScrollView.  The title "Tip Calculator" lives in the toolbar;
    the three-line menu icon appears in the top-right corner of that bar.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ── Toolbar — title left, three-line menu icon right ── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/teal_700"
        app:titleTextColor="@color/white"
        app:title="@string/app_name" />

    <!-- ── Scrollable content area ── -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/surface_variant"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ══════════════════════════════════════════
                 INPUT CARD
                 ══════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Bill Amount label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/label_bill_amount"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp" />

                    <!-- Bill Amount input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilBillAmount"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:prefixText="$"
                        app:prefixTextColor="@color/teal_700">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBillAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_bill_amount"
                            android:inputType="numberDecimal"
                            android:maxLines="1"
                            android:textSize="20sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Tip % label row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_tip_percent"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvTipPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="15%"
                            android:textColor="@color/teal_700"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <!-- SeekBar: 0–30 %, default 15 % -->
                    <SeekBar
                        android:id="@+id/seekBarTip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:max="30"
                        android:progress="15"
                        android:progressTint="@color/teal_500"
                        android:thumbTint="@color/teal_700" />

                    <!-- Quick-tip preset buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn10"
                            style="@style/Widget.TipCalculator.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="10%" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn15"
                            style="@style/Widget.TipCalculator.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="15%" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn18"
                            style="@style/Widget.TipCalculator.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="18%" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn20"
                            style="@style/Widget.TipCalculator.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="20%" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn25"
                            style="@style/Widget.TipCalculator.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="25%" />
                    </LinearLayout>

                    <!-- Split Between label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/label_split"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="13sp" />

                    <!-- Split counter: [−]  count  [+] -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMinus"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:padding="0dp"
                            android:text="@string/btn_minus"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tvSplitCount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:text="1"
                            android:textSize="22sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPlus"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:padding="0dp"
                            android:text="@string/btn_plus"
                            android:textSize="20sp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════════
                 RESULTS CARD
                 ══════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Tip Amount row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_tip_amount"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvTipAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/default_amount"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <!-- Per Person row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_per_person"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvPerPerson"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/default_amount"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <!-- Divider above Total -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/teal_100" />

                    <!-- Total row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:background="@color/total_highlight"
                        android:orientation="horizontal"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/label_total"
                            android:textColor="@color/teal_700"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/tvTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/default_amount"
                            android:textColor="@color/teal_700"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <!-- Swipe hint -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/swipe_hint"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
