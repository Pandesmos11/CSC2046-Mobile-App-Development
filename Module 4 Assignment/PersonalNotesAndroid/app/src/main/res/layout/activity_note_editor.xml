<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_note_editor.xml
    Vertical LinearLayout: toolbar at the top, then a ScrollView
    that fills the remaining space.  Inside the scroll:
      • TextInputLayout (outlined) for the note title
      • Plain, borderless EditText for the note body
    The borderless body EditText intentionally mimics a blank
    sheet of paper.  fillViewport="true" on the ScrollView means
    the body field stretches to fill the screen even when the
    note is short, so taps in the empty area still land in the
    EditText and open the keyboard.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ── Toolbar — back icon left, Save / Delete icons right ── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarEditor"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/blue_700"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/white"
        app:titleTextColor="@color/white" />

    <!-- ── Scrollable editing area ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title field (outlined Material style) -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/hint_title">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNoteTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text|textCapSentences"
                    android:maxLines="2"
                    android:textSize="18sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Thin divider between title and body -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="12dp"
                android:background="@color/blue_100" />

            <!-- Body — borderless for a clean "paper" feel -->
            <EditText
                android:id="@+id/etNoteBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:gravity="top"
                android:hint="@string/hint_body"
                android:inputType="textMultiLine|textCapSentences"
                android:minHeight="220dp"
                android:textSize="15sp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
